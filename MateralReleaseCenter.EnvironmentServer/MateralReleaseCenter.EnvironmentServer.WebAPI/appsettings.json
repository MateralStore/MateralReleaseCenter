{
  "AccessLog": {
    "MaxBodySize": 2048
  },
  "AllowedHosts": "*",
  "Authorization": {
    "Audience": "WebAPI",
    "Issuer": "Materal.APP",
    "Key": "MateralCMXConfig",
    "ExpiredTime": "18000"
  },
  "Consul": {
    "Enable": true,
    "Name": "MRCESAPI",
    "Host": "http://127.0.0.1:8500",
    "Tags": [ "MateralReleaseCenter" ],
    "HealthInterval": 10,
    "HealthHost": "http://host.docker.internal:8720",
    "ServiceHost": "http://127.0.0.1:8720"
  },
  "EventBus": {
    "HostName": "127.0.0.1",
    "Port": 5672,
    "UserName": "admin",
    "Password": "123456",
    "ExchangeName": "MRCExchange",
    "QueueName": "MRCQueue",
    "NameSuffix": "_Dev",
    "RetryInterval": 5,
    "ErrorMeesageDiscard": false,
    "ClientName": "MRCClient"
  },
  "Exception": {
    "ShowException": false,
    "ErrorMessage": "服务器出错了！请联系管理员。"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "MateralLogger": {
      "Application": "${ApplicationName}",
      "Scopes": {
        "MergeBlockAccessLog": "None"
      },
      "Targets": [
        {
          "Name": "ConsoleLog",
          "Type": "Console",
          "Format": "${DateTime}|${Application}|${Level}|${Scope}|${CategoryName}\r\n${Message}\r\n${Exception}"
        },
        {
          "Name": "AccessLog",
          "Type": "Console",
          "Format": "${DateTime}|${Application}|${Level}|${Scope}|${CategoryName}\r\n${Message}"
        }
      ],
      "Rules": [
        {
          "Name": "配置文件规则",
          "Targets": [
            "ConsoleLog"
          ]
        },
        {
          "Name": "访问日志规则",
          "Targets": [
            "AccessLog"
          ],
          "Scopes": {
            "Default": "None",
            "MergeBlockAccessLog": "Trace"
          }
        }
      ]
    }
  },
  "MergeBlock": {
    "ApplicationName": "MRC-ES",
    "LoadFromRootPath": true,
    "LoadFromPlugins": true,
    "Plugins": []
  },
  "Swagger": {
    "Enable": true,
    "Title": "MRC应用程序",
    "Version": "v1",
    "Description": "提供WebAPI接口",
    "EnableAuthentication": null
  },
  "Web": {
    "BaseUrl": "http://127.0.0.1:8700",
    "HttpBodyMaxSize": 10485760,
    "UsePascalCase": true
  }
}